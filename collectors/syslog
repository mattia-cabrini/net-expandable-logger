#
# syslog collector -- the whole system log of the last ~48h, verbatim, as an
# attachment, with a one-line summary in the body.
TAG=syslog

SRC=${MESSAGES_FILE:-/var/log/messages}
[ -r "$SRC" ] || exit 0   # no log to read -> don't seal -> collector is skipped

# Keep only lines dated within the last 48h (today, yesterday, the day before).
ere=$(since_ere 2)
tmp=$(mktemp) || exit 0
grep -E "^$ere" "$SRC" > "$tmp" 2>/dev/null

lines=$(wc -l < "$tmp" | tr -d ' ')

# Body fragment: just a summary; the full log travels as the attachment.
{
	printf '<h4>syslog (integral)</h4>\n'
	printf '<p>Whole system log, last 48h: %s lines from %s.</p>\n' "$lines" "$SRC"
} > "log.$TAG.html"

# Attachment: the filtered log, plus its entry in the attachment list.
attach "syslog.txt" < "$tmp"
printf '<li>syslog.txt &mdash; system log, last 48h, integral</li>\n' > "attachment.$TAG.html"

rm -f "$tmp"
seal
